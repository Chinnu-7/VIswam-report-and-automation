{
    "version": 2,
    "functions": {
        "api/index.js": {
            "includeFiles": "*.xlsx",
            "memory": 1024,
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/schools/sync-all",
            "schedule": "0 18 * * *"
        },
        {
            "path": "/api/automation/run-dispatch",
            "schedule": "30 18 * * *"
        }
    ]
}